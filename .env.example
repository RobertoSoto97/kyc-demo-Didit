# ─── Didit ───────────────────────────────────────────────
# Obtenelos en: dashboard.didit.me → Desarrolladores

# "ID de la app" que ves en Info de la app
DIDIT_CLIENT_ID=tu_client_id_aqui

# "Clave API" → sección Claves API → Primary
