# ID del workflow "Custom KYC"
# Lo ves en Flujos de trabajo → Custom KYC → copiar ID completo
DIDIT_WORKFLOW_ID=tu_workflow_id_aqui

# ─── Admin ───────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
